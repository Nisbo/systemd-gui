            {
              "type": "command",
              "name": "Show DNS servers",
              "enabled": true,
              "command": "sh -lc 'if command -v resolvectl >/dev/null 2>&1; then resolvectl dns; elif command -v systemd-resolve >/dev/null 2>&1; then systemd-resolve --status | sed -n \"/DNS Servers/,+3p\"; else echo \"Configured nameservers from /etc/resolv.conf:\"; grep -E \"^nameserver\" /etc/resolv.conf || true; fi'",
              "confirm": false,
              "show_menu_after": false
