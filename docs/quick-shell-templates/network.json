            {
              "type": "command",
              "name": "Show DNS status",
              "enabled": true,
              "command": "sh -lc 'if command -v resolvectl >/dev/null 2>&1; then resolvectl status; elif command -v systemd-resolve >/dev/null 2>&1; then systemd-resolve --status; else echo \"resolvectl/systemd-resolve not found. Showing /etc/resolv.conf instead:\"; cat /etc/resolv.conf; fi'",
              "confirm": false,
              "show_menu_after": false
