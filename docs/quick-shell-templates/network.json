            {
              "type": "command",
              "name": "Trace route",
              "enabled": true,
              "command": "sh -lc 'if command -v traceroute >/dev/null 2>&1; then traceroute \"$1\"; elif command -v tracepath >/dev/null 2>&1; then tracepath \"$1\"; else echo \"Install traceroute or iputils-tracepath first.\"; exit 127; fi' sh {host}",
              "confirm": false,
              "show_menu_after": false
            },
            {
              "type": "command",
              "name": "Query DNS name",
              "enabled": true,
              "command": "sh -lc 'if command -v resolvectl >/dev/null 2>&1; then resolvectl query \"$1\"; elif command -v systemd-resolve >/dev/null 2>&1; then systemd-resolve \"$1\"; elif command -v dig >/dev/null 2>&1; then dig \"$1\"; elif command -v nslookup >/dev/null 2>&1; then nslookup \"$1\"; elif command -v getent >/dev/null 2>&1; then getent hosts \"$1\"; else echo \"No DNS lookup tool found. Try installing systemd-resolved, dnsutils or bind9-dnsutils.\"; exit 127; fi' sh {domain}",
              "confirm": false,
              "show_menu_after": false
            }
          ]
