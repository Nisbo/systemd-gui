              "command": "sh -lc 'if command -v resolvectl >/dev/null 2>&1; then resolvectl flush-caches; elif command -v systemd-resolve >/dev/null 2>&1; then systemd-resolve --flush-caches; else echo \"No systemd DNS cache command found on this system.\"; exit 127; fi'",
              "confirm": true,
              "show_menu_after": false
            },
